# Copy this file to .env, then replace only the placeholder values you need.
# Never commit the real .env file or any API key.
# Do not add GitHub tokens, passwords, private keys, or personal paths here.

# OpenAI
OPENAI_API_KEY=your_api_key_here
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-5.5

# Local runtime data paths (relative to the project root)
UPLOAD_DIR=data/uploads
CHROMA_DB_DIR=data/chroma_db
METADATA_DB_PATH=data/metadata.db

# Retrieval parameters
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=3
SIMILARITY_THRESHOLD=0.6
DEFAULT_RETRIEVAL_MODE=vector
VECTOR_CANDIDATE_K=8
BM25_CANDIDATE_K=8
RRF_K=60

# Frontend-to-backend address. Keep this value for local runs.
# Docker Compose overrides it with http://backend:8000.
API_BASE_URL=http://127.0.0.1:8000

# Optional Docker host bindings and named volume.
BACKEND_PORT=8000
FRONTEND_PORT=8501
DATA_VOLUME_NAME=rag-knowledge-assistant-data
